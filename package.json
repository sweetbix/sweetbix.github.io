{
  "scripts": {
    "dev": "tailwindcss -i old-style.css -o tailwind.css --watch",
    "serve": "live-server --port=3000 --open=/index.html",
    "live": "concurrently -n css,site -c cyan,magenta \"tailwindcss -i old-style.css -o tailwind.css --watch\" \"live-server --port=3000 --open=/index.html\""
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.1.11",
    "tailwindcss": "^4.1.11"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "live-server": "^1.2.2"
  }
}
